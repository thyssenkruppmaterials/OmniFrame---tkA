# rust-dashboard-service Environment Configuration
# Part of: Comprehensive Authentication Security Overhaul - Phase 1
# Created: January 27, 2026

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
PORT=8002
RUST_LOG=info,rust_dashboard_service=debug

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct database connection for aggregation queries
DATABASE_URL=postgres://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres

# =============================================================================
# RUST-CORE-SERVICE AUTHENTICATION (Required)
# =============================================================================
# URL of the rust-core-service for JWT validation
RUST_CORE_URL=http://localhost:8010

# Service API key for authenticating with rust-core-service
# Generate with: python api/scripts/generate_service_api_key.py --service rust-dashboard-service
# Format: omf_da_<32_random_hex_chars>
RUST_CORE_API_KEY=omf_da_<your_generated_key>

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://omniframe.example.com

# =============================================================================
# AGGREGATION SETTINGS
# =============================================================================
# How often to run statistics aggregation (in seconds)
AGGREGATION_INTERVAL_SECONDS=300

# Maximum age of cached statistics (in seconds)
CACHE_TTL_SECONDS=60

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
# Enable detailed request logging
ENABLE_REQUEST_LOGGING=true

# Metrics endpoint exposure
ENABLE_METRICS=true
