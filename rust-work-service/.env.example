# rust-work-service Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# PostgreSQL connection URL — DIRECT connection (port 5432).
#
# This URL MUST point at the database's direct port, NOT a transaction-mode
# pooler. Every `LISTEN/NOTIFY` consumer in the service (10+ tasks at boot)
# needs a long-lived dedicated socket that transaction-mode pooling
# multiplexes to death — sqlx PgListener against a pooled URL fails to
# receive frames at all.
#
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:password@localhost:5432/onebox

# OPTIONAL — Supavisor / PgBouncer transaction-mode pooler URL (port 6543).
#
# When set, the general-purpose sqlx pool (HTTP routes + scheduler + WS
# handler) routes through it instead of the direct DATABASE_URL. The
# listener-dedicated sqlx pool (every `*_listener.rs` consumer + the
# triggers loader/evaluator) ALWAYS uses DATABASE_URL because LISTEN/NOTIFY
# is incompatible with transaction-mode pooling (see comment above).
#
# Setting this in production frees direct-connection slots back to pg_cron
# and other non-pooled clients. The 2026-05-07 audit observed the database
# at 113/120 connections (94% utilization) with pg_cron failing ~1.5% of
# runs because slots weren't available — this knob is the mitigation.
#
# Supavisor URL pattern (transaction mode):
#   postgresql://postgres.{project_ref}:{password}@aws-0-{region}.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Acceptable env-var aliases (first match wins):
#   1. WORK_SERVICE_DATABASE_POOLER_URL   (canonical)
#   2. DATABASE_POOLER_URL                (shorter alias for parity with DATABASE_URL)
#
# Unset = backwards-compatible — the general-purpose pool falls back to
# DATABASE_URL.
# WORK_SERVICE_DATABASE_POOLER_URL=postgresql://postgres.wncpqxwmbxjgxvrpcake:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Redis connection URL
# Format: redis://[[user]:password@]host[:port][/database]
# For Redis Cloud: redis://default:password@host:port
REDIS_URL=redis://localhost:6379

# Service API key for authenticating with rust-core-service
# Format: onbx_wk_<32_hex_chars>
# Generate a new key for this service and register it in rust-core-service
RUST_CORE_API_KEY=onbx_wk_your_service_api_key_here

# =============================================================================
# OPTIONAL VARIABLES (with defaults)
# =============================================================================

# HTTP server port (default: 8030)
PORT=8030

# rust-core-service URL for auth validation (default: http://localhost:8010)
RUST_CORE_URL=http://localhost:8010

# Supabase URL (optional, for storage operations)
# SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (optional)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# =============================================================================
# CORS (optional)
# =============================================================================

# Comma-separated allowed origins — set to your frontend domain(s) in production
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# LOGGING (optional)
# =============================================================================

# Log level filter (default: rust_work_service=debug,tower_http=debug)
# Examples:
#   - RUST_LOG=info (production)
#   - RUST_LOG=debug (development)
#   - RUST_LOG=rust_work_service=trace,tower_http=debug (verbose)
# RUST_LOG=info
