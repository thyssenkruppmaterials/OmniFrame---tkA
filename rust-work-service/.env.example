# rust-work-service Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# PostgreSQL connection URL (Supabase or direct PostgreSQL)
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:password@localhost:5432/omniframe

# Redis connection URL
# Format: redis://[[user]:password@]host[:port][/database]
# For Redis Cloud: redis://default:password@host:port
REDIS_URL=redis://localhost:6379

# Service API key for authenticating with rust-core-service
# Format: omf_wk_<32_hex_chars>
# Generate a new key for this service and register it in rust-core-service
RUST_CORE_API_KEY=omf_wk_your_service_api_key_here

# =============================================================================
# OPTIONAL VARIABLES (with defaults)
# =============================================================================

# HTTP server port (default: 8030)
PORT=8030

# rust-core-service URL for auth validation (default: http://localhost:8010)
RUST_CORE_URL=http://localhost:8010

# Supabase URL (optional, for storage operations)
# SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (optional)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# =============================================================================
# CORS (optional)
# =============================================================================

# Comma-separated allowed origins — set to your frontend domain(s) in production
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# LOGGING (optional)
# =============================================================================

# Log level filter (default: rust_work_service=debug,tower_http=debug)
# Examples:
#   - RUST_LOG=info (production)
#   - RUST_LOG=debug (development)
#   - RUST_LOG=rust_work_service=trace,tower_http=debug (verbose)
# RUST_LOG=info
