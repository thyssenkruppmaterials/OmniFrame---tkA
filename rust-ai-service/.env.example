# rust-ai-service Environment Configuration
# Part of: Comprehensive Authentication Security Overhaul - Phase 1
# Created: January 27, 2026

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
PORT=8001
RUST_LOG=info,drone_ai_service=debug

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Direct database connection (for better performance)
# DATABASE_URL=postgres://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres

# =============================================================================
# RUST-CORE-SERVICE AUTHENTICATION (Required)
# =============================================================================
# URL of the rust-core-service for JWT validation
RUST_CORE_URL=http://localhost:8010

# Service API key for authenticating with rust-core-service
# Generate with: python api/scripts/generate_service_api_key.py --service rust-ai-service
# Format: omf_ai_<32_random_hex_chars>
RUST_CORE_API_KEY=omf_ai_<your_generated_key>

# =============================================================================
# AI SERVICE CONFIGURATION
# =============================================================================
# Hugging Face API key for AI model inference
HUGGINGFACE_API_KEY=hf_your_api_key_here

# Optional: Novita AI API key for additional AI capabilities
NOVITA_API_KEY=

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://omniframe.example.com

# =============================================================================
# RATE LIMITING
# =============================================================================
# Maximum requests per minute per client
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
# Enable detailed request logging
ENABLE_REQUEST_LOGGING=true

# Metrics endpoint exposure
ENABLE_METRICS=true
