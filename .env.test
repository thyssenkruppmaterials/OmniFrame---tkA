# Minimal test environment configuration for backend (Python) tests.
# No secrets — safe to commit. Used by CI and local pytest runs.
#
# Encoding policy: UTF-8 without BOM. See docs/quality/env-encoding-policy.md.

TESTING=true
API_DEBUG=true
API_LOG_LEVEL=WARNING
API_SUPABASE_URL=https://placeholder.supabase.co
API_SUPABASE_ANON_KEY=placeholder-anon-key
RUST_CORE_ENABLED=false
RUST_CORE_FALLBACK=false
REDIS_URL=redis://localhost:6379
