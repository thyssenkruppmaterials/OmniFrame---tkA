# rust-mdm-service Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# PostgreSQL connection URL (Supabase Postgres)
DATABASE_URL=postgres://postgres:password@localhost:5432/onebox

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Service API key for authenticating with rust-core-service
RUST_CORE_API_KEY=onbx_mdm_your_service_api_key_here

# =============================================================================
# OPTIONAL VARIABLES (with defaults)
# =============================================================================

# HTTP server port (default: 8040)
PORT=8040

# rust-core-service URL for auth validation (default: http://localhost:8010)
RUST_CORE_URL=http://localhost:8010

# =============================================================================
# CORS
# =============================================================================

# Comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# APPLE MDM
# =============================================================================

# Base URL for device-facing MDM endpoints (must be HTTPS in production)
MDM_BASE_URL=https://mdm.yourdomain.com

# APNs MDM push certificate (certificate-based auth, NOT token auth)
# APNS_CERT_PATH=/path/to/apns-mdm-cert.p12
# APNS_CERT_PASSWORD=your_cert_password

# ABM/ADE server token
# ABM_SERVER_TOKEN_PATH=/path/to/abm-server-token.p7m

# Enrollment profile signing certificate
# PROFILE_SIGNING_CERT_PATH=/path/to/signing-cert.pem
# PROFILE_SIGNING_KEY_PATH=/path/to/signing-key.pem

# SCEP CA certificate and key
# SCEP_CA_CERT_PATH=/path/to/scep-ca-cert.pem
# SCEP_CA_KEY_PATH=/path/to/scep-ca-key.pem

# =============================================================================
# TELEMETRY AGENT
# =============================================================================

# Shared secret for telemetry agent bootstrap authentication
# TELEMETRY_SHARED_SECRET=your_shared_secret_here

# =============================================================================
# LOGGING
# =============================================================================

# RUST_LOG=info
