  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "frontend:build": "tsc -b && vite build",
    "build:legacy-cache-bust": "npm run frontend:build && npm run generate-build-info",
    "generate-build-info": "node scripts/generate-build-info.js",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "knip": "knip",
    "create-admin": "node scripts/create-admin.js",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:perf": "cross-env INTEGRATION_MODE=infra INTEGRATION_PROFILE=perf vitest run --config vitest.integration.config.ts",
    "test:integration:infra:repeat": "cross-env INTEGRATION_MODE=infra vitest run --config vitest.integration.config.ts && cross-env INTEGRATION_MODE=infra vitest run --config vitest.integration.config.ts && cross-env INTEGRATION_MODE=infra vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run --config vitest.config.ts && vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "cache:clear": "node scripts/clear-cache.js",
    "quality:check": "node scripts/check-tracked-artifacts.mjs && node scripts/check-forbidden-client-env.mjs && pnpm lint:check && node scripts/lint-ratchet.mjs && pnpm format:check && pnpm build && node scripts/check-bundle-budget.mjs && node scripts/validate-check-matrix.mjs && pnpm test:unit",
    "quality:ci": "node scripts/check-tracked-artifacts.mjs && node scripts/check-forbidden-client-env.mjs && pnpm lint:check && node scripts/lint-ratchet.mjs && pnpm format:check && pnpm build && node scripts/check-bundle-budget.mjs && node scripts/validate-check-matrix.mjs && pnpm test:unit",
    "prepare": "husky"
  },
