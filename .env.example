# ==============================================================================
# OneBox AI — Environment Variables
#
# Copy this file to .env.local (frontend) or .env (API) and fill in real values.
# NEVER commit secrets to version control.
# ==============================================================================

# --- Frontend (Vite) ---------------------------------------------------------
# These variables are embedded into the browser bundle at build time.
# Only VITE_* variables are exposed to client code.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# !! SECURITY: NEVER set this for frontend/production builds !!
# The build will fail if this is defined during a production build.
# Service-role access must only happen server-side (Python API).
# VITE_SUPABASE_SERVICE_ROLE_KEY=   <-- DO NOT SET

# Canonical frontend URL used in Supabase auth email redirects (password reset, sign-up verification).
# Must also be added to Supabase Dashboard > Authentication > URL Configuration > Redirect URLs.
VITE_APP_URL=https://onebox-ai-logistics-production.up.railway.app

VITE_API_URL=http://localhost:8000
VITE_RUST_CORE_ENABLED=true
VITE_RUST_CORE_URL=https://rust-core-service-production.up.railway.app

# rust-work-service (Axum + Tokio + sqlx + bb8-redis). Owns the work queue,
# org-scoped pub/sub WebSocket bus, presence, entity-focus, notifications.
# Production deploy lives at https://rust-work-service-production.up.railway.app
# (separate Railway service from rust-core-service; they're coupled — work-service
# delegates JWT validation to core-service via POST {core}/api/v1/auth/validate-with-profile).
# For local dev override to localhost:8030 below.
VITE_WORK_SERVICE_URL=http://localhost:8030
VITE_WORK_SERVICE_WS_URL=ws://localhost:8030/ws
# Production values (commented for clarity — set the real URLs in Railway env, NOT here):
# VITE_WORK_SERVICE_URL=https://rust-work-service-production.up.railway.app
# VITE_WORK_SERVICE_WS_URL=wss://rust-work-service-production.up.railway.app/ws

VITE_STREAMING_SERVICE_URL=http://localhost:8020

# --- Realtime Presence kill switch ------------------------------------------
# Browser-side equivalent of the OmniFrame agent's OMNIFRAME_DISABLE_REALTIME=1
# escape hatch. Set to "true" / "1" to skip the org-wide Supabase Presence
# channel join + DB heartbeat at boot. Use when the Realtime tenant is
# degraded (e.g. Presence_shard### GenServer wedged) and you need to bleed
# off load fleet-wide. Inlined at build time — requires a fresh build to
# take effect, no runtime toggle. Default: unset (presence enabled).
# VITE_PRESENCE_DISABLED=true

# --- Presence backend selector (Option 2) -----------------------------------
# Selects which presence implementation runs at module load. See
# `memorybank/OmniFrame/Decisions/ADR-Presence-Architecture-Next-Steps.md`
# (Option 2) and `Implementations/Implement-Presence-On-Rust-Option-2`.
#
#   - 'supabase' (default) — current Phase A+B2+B3 implementation on
#     Supabase Realtime presence channels. Behaviour shipped through
#     2026-05-06.
#   - 'rust'               — server-side presence in `rust-work-service`.
#     Browsers heartbeat to `POST /api/v1/presence/heartbeat` and consume
#     `Presence{Joined,Updated,Left}` events from the existing
#     `WorkServiceWebSocket` singleton. Removes the Supabase Presence
#     channel from the critical path entirely.
#   - 'disabled'           — same effect as VITE_PRESENCE_DISABLED=true.
#     Provided so a per-tenant build can express "presence off" in one knob.
#
# Inlined at build time — same caveat as VITE_PRESENCE_DISABLED. Default
# unset (== 'supabase'). VITE_PRESENCE_DISABLED=true wins regardless of
# this value.
#
# v1.8.5 (Phase 1 of rust-work-service integration plan, 2026-05-06):
# RECOMMENDED SETTING IN RAILWAY PRODUCTION ENV: 'rust' — the Customer
# Portal Presence GenServer overload that triggered the agent v1.7.1→v1.8.4
# storm is fixed by routing presence through rust-work-service. Cure has
# shipped (commit c2e4ed3); enable in production by setting:
#   VITE_PRESENCE_MODE=rust
# in the Railway service env vars (NOT this file). See
# memorybank/OmniFrame/Decisions/Roadmap-Rust-WS-Unlocks.md.
# VITE_PRESENCE_MODE=rust

# --- Python API (FastAPI) ----------------------------------------------------
# These are read by api/config/settings.py. Prefix with API_ or use the
# canonical names below.

ENVIRONMENT=development
PORT=8000

# Supabase (API-side — use API_ prefix or canonical names)
API_SUPABASE_URL=https://your-project.supabase.co
API_SUPABASE_ANON_KEY=your-supabase-anon-key
API_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Frontend URL for auth email redirects (password reset, invitations)
FRONTEND_URL=https://onebox-ai-logistics-production.up.railway.app

# Authentication
JWT_SECRET_KEY=your-jwt-secret

# Rust Core Service
RUST_CORE_URL=https://rust-core-service-production.up.railway.app
RUST_CORE_ENABLED=true
RUST_CORE_TIMEOUT=10.0
RUST_CORE_RETRY_ATTEMPTS=3
RUST_CORE_FALLBACK=false
ALLOW_INSECURE_JWT_FALLBACK=false

# Redis
REDIS_URL=redis://localhost:6379

# Smartsheet
SMARTSHEET_ACCESS_TOKEN=your-smartsheet-token

# Nefab PFC Trace
NEFAB_API_KEY=your-nefab-api-key

# --- OmniFrame on-prem agent (omni_agent/agent.py) --------------------------
# These env vars are read by the desktop agent (PyInstaller-bundled
# OmniFrame_Agent.exe). Set them in the Windows operator environment, NOT in
# this file's parent process. Documented here for the runbook.

# Phase 4 of the rust-work-service integration plan (2026-05-06).
# When set to `1`, the agent replaces its direct Supabase Realtime
# subscription on `sap_agent_jobs` + `rf_putaway_operations` with a
# single connection to `rust-work-service /ws`. The agent consumes
# `WsEvent::SapJobStatusChanged` (job-poller wake-up) and
# `WsEvent::RfPutawayChanged` (trigger evaluator wake-up).
#
# Default (unset / `0`): legacy Supabase Realtime path runs unchanged.
# This stays the default through the 3-day parallel-run window
# documented in
# `memorybank/OmniFrame/Implementations/Implement-Rust-Work-Service-Phase4.md`.
# After telemetry shows event-rate parity between the two paths, the
# operator flips to `1` and v1.10 of the agent deletes the legacy code.
# OMNIFRAME_AGENT_USE_RUST_WS=0

# Override the rust-work-service URL the agent connects to. Honored
# only when `OMNIFRAME_AGENT_USE_RUST_WS=1`. Defaults to the production
# Railway deploy when unset.
# OMNIFRAME_WORK_SERVICE_URL=https://rust-work-service-production.up.railway.app

# Phase 10 of the rust-work-service integration plan (2026-05-07) —
# agent identity v2. Path to the on-disk plaintext `omni_sk_*` service
# key. The agent reads this file at boot, exchanges the key at
# `POST /api/v1/agent-identity/exchange`, and uses the returned
# 15-minute JWT (`kind: "agent"`) for both WS subscribe-token mints
# and `/api/v1/sap-agents/jobs/*` HTTP calls. Override only if you
# don't want the default per-user XDG-shaped path.
#
# Default (POSIX):   ~/.omniframe/agent_service_key.txt
# Default (Windows): %USERPROFILE%\.omniframe\agent_service_key.txt
#
# When the file is absent the agent stays on the legacy user-JWT
# path (the agent inherits a human user's Supabase session via
# /supabase/login). Phase 11 owns the cleanup that removes the
# legacy path entirely.
# OMNIFRAME_AGENT_SERVICE_KEY_PATH=~/.omniframe/agent_service_key.txt

# Phase 10 — HMAC secret used by rust-work-service to sign the
# `kind: "agent"` JWTs it issues from `POST /api/v1/agent-identity/exchange`.
# Verified locally in `crate::middleware::require_auth`. MUST be a
# strong random value in production (32+ bytes); the service falls
# back to a deterministic dev-only string with a startup warning when
# unset to keep local dev frictionless. Rotate by setting a new value
# and bouncing rust-work-service — every in-flight agent JWT becomes
# invalid (forcing the next refresh tick to re-exchange against the
# new secret). See `Decisions/ADR-Agent-Identity-V2-Phase10.md`.
# WORK_SERVICE_AGENT_JWT_SECRET=replace-me-with-32-random-bytes-base64

# Phase 7 of the rust-work-service integration plan (2026-05-06).
# When set to `1` (default since v2.0.0 / Phase 11), the agent routes
# its hot-path queue writes (claim → complete/fail → heartbeat)
# through `rust-work-service /api/v1/sap-agents/jobs/...` instead of
# direct PostgREST. Setting back to `0` is supported as a soft
# fallback in v2.0.x but logs a deprecation warning at boot — the
# legacy direct-PostgREST claim/complete/fail/lease-bump fallback
# bodies were DELETED in Phase 11, so `=0` will produce errors. The
# env var itself is scheduled for removal in v2.1.0. See
# `memorybank/OmniFrame/Implementations/Implement-Rust-Work-Service-Phase7.md`.
# OMNIFRAME_AGENT_CLAIM_VIA_RUST=1

# Phase 6 of the rust-work-service integration plan (2026-05-07).
# When set to `1` (default since v2.0.0 / Phase 11), the agent's
# `_console_relay_thread` mirrors selected stdout/stderr lines to
# `rust-work-service /api/v1/sap-console/lines` so the SAP Console
# card in the web app can render them in real time. Buffer cap
# 10000 lines, batch size 50, flush every ~500ms. Setting to `0`
# disables the relay and logs a deprecation warning. The env var
# is scheduled for removal in v2.1.0. See
# `memorybank/OmniFrame/Implementations/Implement-Rust-Work-Service-Phase6.md`.
# OMNIFRAME_AGENT_CONSOLE_RELAY=1

# Phase 11 of the rust-work-service integration plan (2026-05-07).
# When set to `1`, upgrades the missing-service-key boot warning
# to a hard-fail (exit 78). Use this on production agents once
# every Citrix box has a service key on disk so a botched
# deployment fails loud instead of silently falling back to the
# legacy user-JWT path. Default unset (`0`) keeps the soft warning
# during the v2.0.x rollout window. See
# `memorybank/OmniFrame/Decisions/ADR-Agent-2.0.0-Release.md`.
# OMNIFRAME_AGENT_REQUIRE_SERVICE_KEY=1

# Agent-side Realtime kill switch. When set to `1`, the agent
# skips its Supabase Realtime subscription entirely and falls back
# to polling-only mode (job poller 5–15s, backfill poller 60s).
# Use during a Realtime tenant outage to bleed off load
# fleet-wide. v2.0.0 default-flipped `OMNIFRAME_AGENT_USE_RUST_WS=1`
# so most agents already use rust-work-service /ws — this knob
# disables the legacy Supabase Realtime fallback path entirely.
# Default unset.
# OMNIFRAME_DISABLE_REALTIME=1

# v1.7.0 stuck-job watchdog timeout (seconds). Jobs whose
# `started_at` is older than this threshold are marked `failed`
# via `_work_service_fail` (Phase 7) and released back to the
# queue. Default 300s (5 minutes) — long enough to absorb a slow
# but progressing SAP COM call, short enough that a hard agent
# hang doesn't stall the queue indefinitely. Watchdog ticks every
# 30s.
# OMNIFRAME_JOB_WATCHDOG_TIMEOUT_SECONDS=300
