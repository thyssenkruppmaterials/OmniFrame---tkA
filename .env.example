# ==============================================================================
# OmniFrame — Environment Variables
#
# Copy this file to .env.local (frontend) or .env (API) and fill in real values.
# NEVER commit secrets to version control.
# ==============================================================================

# --- Frontend (Vite) ---------------------------------------------------------
# These variables are embedded into the browser bundle at build time.
# Only VITE_* variables are exposed to client code.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# !! SECURITY: NEVER set this for frontend/production builds !!
# The build will fail if this is defined during a production build.
# Service-role access must only happen server-side (Python API).
# VITE_SUPABASE_SERVICE_ROLE_KEY=   <-- DO NOT SET

VITE_API_URL=http://localhost:8000
VITE_RUST_CORE_ENABLED=true
VITE_RUST_CORE_URL=https://your-rust-core-service.up.railway.app
VITE_WORK_SERVICE_URL=http://localhost:8030
VITE_WORK_SERVICE_WS_URL=ws://localhost:8030/ws
VITE_STREAMING_SERVICE_URL=http://localhost:8020

# --- Python API (FastAPI) ----------------------------------------------------
# These are read by api/config/settings.py. Prefix with API_ or use the
# canonical names below.

ENVIRONMENT=development
PORT=8000

# Supabase (API-side — use API_ prefix or canonical names)
API_SUPABASE_URL=https://your-project.supabase.co
API_SUPABASE_ANON_KEY=your-supabase-anon-key
API_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Authentication
JWT_SECRET_KEY=your-jwt-secret

# Rust Core Service
RUST_CORE_URL=https://your-rust-core-service.up.railway.app
RUST_CORE_ENABLED=true
RUST_CORE_TIMEOUT=10.0
RUST_CORE_RETRY_ATTEMPTS=3
RUST_CORE_FALLBACK=false
ALLOW_INSECURE_JWT_FALLBACK=false

# Redis
REDIS_URL=redis://localhost:6379

# Smartsheet
SMARTSHEET_ACCESS_TOKEN=your-smartsheet-token

# Nefab PFC Trace
NEFAB_API_KEY=your-nefab-api-key
